    "description": "PostgreSQL MCP server via Docker — zero-install database access.",
    "type": "docker",
    "latestVersion": "1.0.0",
    "authors": ["community"],
    "license": "MIT",
    "versions": {
      "1.0.0": {
        "handlerArgs": {
          "image": "mcp/postgres:1.0.0",
          "ports": ["5432:5432"],
          "volumes": ["pgdata:/var/lib/postgresql/data"]
        },
        "defaultEnv": {
          "POSTGRES_PASSWORD": "secret"
        }
      }
